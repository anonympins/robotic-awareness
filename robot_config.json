{
  "version": "1.0",
  "metadata": { "name": "Main-Bio-Sensorisee-v1" },
  "system_settings": {
    "loop_frequency_hz": 50,
    "ik_solver_type": "DampedLeastSquares",
    "ik_precision_threshold": 0.001,
    "max_ik_iterations": 50
  },
  "variables": {
    "temp_high": 0,
    "contact": 1,
    "fire_detected": 2,
    "is_slippery": 3,
    "tilt_critical": 4,
    "object_grasped": 5,
    "overpressure": 6
  },
  "sensors": {
    "maillage_main": {
      "type": "analog_array",
      "resolution": [3, 2],
      "mapping": [
        { "id": "idx_p1", "pin": "A0", "label": "Index P1" },
        { "id": "idx_p2", "pin": "A1", "label": "Index P2" },
        { "id": "idx_p3", "pin": "A2", "label": "Index P3" },
        { "id": "maj_p1", "pin": "A3", "label": "Majeur P1" },
        { "id": "maj_p2", "pin": "A4", "label": "Majeur P2" },
        { "id": "maj_p3", "pin": "A5", "label": "Majeur P3" },
        { "id": "ann_p1", "pin": "A6", "label": "Annulaire P1" },
        { "id": "ann_p2", "pin": "A7", "label": "Annulaire P2" },
        { "id": "ann_p3", "pin": "A8", "label": "Annulaire P3" },
        { "id": "aur_p1", "pin": "A9", "label": "Auriculaire P1" },
        { "id": "aur_p2", "pin": "A10", "label": "Auriculaire P2" },
        { "id": "aur_p3", "pin": "A11", "label": "Auriculaire P3" },
        { "id": "pouce_p1", "pin": "A12", "label": "Pouce P1" },
        { "id": "pouce_p2", "pin": "A13", "label": "Pouce P2" }
      ]
    },
    "torque_wrist": { "type": "analog", "pin": "A6", "label": "Torque Poignet" }
  },
  "logic": {
    "safety_ok": {
      "type": "AND",
      "args": [
        { "type": "NOT", "args": [{ "var": "fire_detected" }] },
        { "type": "NOT", "args": [{ "var": "overpressure" }] }
      ]
    },
    "behavior": {
        "bit_0_grasp": { "var": "contact" },
        "bit_1_release": { "type": "NOT", "args": [{ "var": "contact" }] },
        "bit_2_emergency_open": { "var": "overpressure" }
    }
  },
  "kinematics": {
    "workspace_envelope": {
      "center": [0, 0, 0],
      "radius_max": 0.2,
      "radius_min": 0.0
    },
    "index": {
